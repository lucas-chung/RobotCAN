<mujoco model="robotcan_joint">
  <compiler angle="degree" autolimits="true"/>

  <option timestep="0.002" gravity="0 0 0" integrator="RK4"/>

  <default>
    <joint type="hinge" axis="0 0 1" limited="true" range="-180 180" damping="0.8" armature="0.01"/>
    <geom type="capsule" size="0.025 0.18" density="1200" friction="0.8 0.1 0.1" rgba="0.2 0.5 0.9 1"/>
    <motor ctrllimited="true" ctrlrange="-50 50"/>
  </default>

  <visual>
    <headlight ambient="0.35 0.35 0.35" diffuse="0.65 0.65 0.65" specular="0.2 0.2 0.2"/>
    <rgba haze="0.15 0.2 0.25 1"/>
  </visual>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1"/>

    <body name="base" pos="0 0 0">
      <geom name="base_geom" type="cylinder" size="0.05 0.04" rgba="0.35 0.35 0.35 1"/>

      <body name="link1" pos="0 0 0.04">
        <joint name="joint1"/>
        <geom name="link1_geom" fromto="0 0 0 0.35 0 0"/>
        <site name="joint_center" pos="0 0 0" size="0.01" rgba="1 0 0 1"/>
        <site name="tip" pos="0.35 0 0" size="0.012" rgba="0 1 0 1"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="joint1_motor" joint="joint1" gear="1"/>
  </actuator>

  <sensor>
    <jointpos name="joint1_pos" joint="joint1"/>
    <jointvel name="joint1_vel" joint="joint1"/>
    <actuatorfrc name="joint1_torque" actuator="joint1_motor"/>
  </sensor>

  <keyframe>
    <key name="home" qpos="0" ctrl="0"/>
  </keyframe>
</mujoco>
